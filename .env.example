# --- API Keys (at least one required; falls back to local HF embeddings + MockLLM if none set) ---
GEMINI_API_KEY="your key"
OPENAI_API_KEY="your key"
COHERE_API_KEY="your key"

# --- Provider selection ---
EMBEDDING_PROVIDER=gemini
LLM_PROVIDER=gemini

# --- Reranker: "local" (free, self-hosted cross-encoder), "cohere" (hosted, needs COHERE_API_KEY), "none" ---
RERANKER_PROVIDER=local
LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Retrieval tuning ---
VECTOR_TOP_K=10
BM25_TOP_K=10
FUSION_NUM_QUERIES=3
RERANK_TOP_N=5
ENABLE_HYDE=true

# --- Chunking tuning ---
CODE_CHUNK_LINES=40
CODE_CHUNK_LINES_OVERLAP=10
CODE_MAX_CHARS=1500
TEXT_CHUNK_SIZE=512
TEXT_CHUNK_OVERLAP=64
